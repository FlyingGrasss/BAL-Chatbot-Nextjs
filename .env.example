GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2
# GEMINI_API_KEY_2=
GEMINI_MODEL_CHAIN=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash-lite
GEMINI_SEARCH_GROUNDING=true
GEMINI_SEARCH_MODEL=gemini-3.1-flash-lite

# Used only when every Gemini attempt fails.
GROQ_API_KEY=
# GROQ_API_KEYS=key1,key2,key3
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=
# GROQ_API_KEY_4=
# GROQ_API_KEY_5=

# Hugging Face Inference API token for query embeddings.
HF_TOKEN=
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Optional but recommended for production.
DATABASE_URL=

# Required for /admin feedback view.
ADMIN_PASSWORD=

# Shared anti-abuse guard. IPs are hashed before they are stored.
IP_DAILY_LIMIT=300
IP_MINUTE_LIMIT=30
